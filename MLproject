name: california-housing

python_env: python_env.yaml

entry_points:
    main:
        parameters:
            n_estimators:
                type: int
                default: 100
            max_depth :
                type: int
                default: 10
            learning_rate:
                type: float
                default: 0.1
            model_type:
                type: string
                default: 'random_forest'
        command: >
            python train.py
            --n-estimators {n_estimators}
            --max-depth {max_depth}
            --model-type {model_type}
        